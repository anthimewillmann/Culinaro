<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ingredients_count</key>
	<dict>
		<key>NSStringLocalizedFormatKey</key>
		<string>%#@ingredients@</string>
		<key>ingredients</key>
		<dict>
			<key>NSStringFormatSpecTypeKey</key>
			<string>NSStringPluralRuleType</string>
			<key>NSStringFormatValueTypeKey</key>
			<string>d</string>
			<key>one</key>
			<string>%d Zutat</string>
			<key>other</key>
			<string>%d Zutaten</string>
		</dict>
	</dict>
	<key>recipes_count</key>
	<dict>
		<key>NSStringLocalizedFormatKey</key>
		<string>%#@recipes@</string>
		<key>recipes</key>
		<dict>
			<key>NSStringFormatSpecTypeKey</key>
			<string>NSStringPluralRuleType</string>
			<key>NSStringFormatValueTypeKey</key>
			<string>d</string>
			<key>one</key>
			<string>%d Rezept</string>
			<key>other</key>
			<string>%d Rezepte</string>
		</dict>
	</dict>
	<key>steps_count</key>
	<dict>
		<key>NSStringLocalizedFormatKey</key>
		<string>%#@steps@</string>
		<key>steps</key>
		<dict>
			<key>NSStringFormatSpecTypeKey</key>
			<string>NSStringPluralRuleType</string>
			<key>NSStringFormatValueTypeKey</key>
			<string>d</string>
			<key>one</key>
			<string>%d Schritt</string>
			<key>other</key>
			<string>%d Schritte</string>
		</dict>
	</dict>
</dict>
</plist>
